APP_NAME="AlcoGest"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Paris

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=alcogest
DB_USERNAME=postgres
DB_PASSWORD=secret

BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@alcogest.fr"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=+33600000000

# Recherche d'image en ligne (Google Custom Search)
# 1. https://console.cloud.google.com/ → créer un projet → activer "Custom Search API" → "Identifiants" → créer une clé API
# 2. https://programmablesearchengine.google.com/ → nouveau moteur → activer "Recherche d'images" et "Tout le Web" → copier l'ID (cx)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

VITE_APP_NAME="${APP_NAME}"
